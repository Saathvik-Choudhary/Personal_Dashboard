{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "predeploy": [
        "node_modules/.bin/tsc -p packages/core/tsconfig.json",
        "node functions/esbuild.mjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "src",
        "esbuild.mjs",
        "tsconfig.json",
        "*.tsbuildinfo"
      ]
    }
  ],
  "hosting": {
    "public": "apps/dashboard/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
