# Orbit environment template — copy to .env and fill in. NEVER commit the real .env.
# Cloud secrets live in Google Secret Manager; daemon secrets in macOS Keychain or a
# gitignored .env. The Firebase *web* config (NEXT_PUBLIC_*) is public by design.

# --- Anthropic (functions + daemon; server-side only, never shipped to the client) ---
ANTHROPIC_API_KEY=

# --- Twilio WhatsApp (functions) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Google Calendar OAuth (functions) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# --- Firebase Admin (functions + daemon) ---
# Daemon: path to a gitignored service-account JSON. Functions use ambient creds.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
FIREBASE_PROJECT_ID=

# --- Single-user bootstrap: the uid the daemon operates on ---
ORBIT_USER_UID=

# --- Firebase web config (dashboard) — public, safe to ship ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# FCM Web Push (VAPID) public key — also public
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
