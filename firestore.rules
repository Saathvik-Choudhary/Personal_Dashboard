rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Clients may only touch their own subtree. The daemon and Cloud Functions
    // use the Admin SDK and bypass these rules entirely (spec §5).
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
